# Copy to `.env` in the repo root (Murmur loads it automatically on CLI startup).

# --- Model provider (default: deepseek) ---
MURMUR_MODEL_PROVIDER=deepseek
MURMUR_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=

# V4 Pro reasoning + thinking (passed to chat.completions.create)
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_THINKING=enabled
DEEPSEEK_MAX_TOKENS=8192
# Reasoning-starvation safety net: minimum output budget per call and the cap the
# harness escalates to when a reasoning call returns no final content.
DEEPSEEK_MIN_OUTPUT_TOKENS=2048
DEEPSEEK_MAX_ESCALATION_TOKENS=16384
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- Agent task (default: hard) ---
# demo = echo uppercase smoke test | hard = full landing-site build
MURMUR_TASK=hard

# Anthropic (when MURMUR_MODEL_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=

# --- Murmur runtime ---
MURMUR_EVENT_LOG=.murmur/events.jsonl
MURMUR_TRACE_BACKEND=none
MURMUR_CAPTURE_CONTENT=false
OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental

# LangSmith export (optional)
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=murmur
